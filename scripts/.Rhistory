library(ggplot2)
library(tidyr)
# Data
data <- data.frame(
Sample = c("SRR8902718","SRR8902718","SRR8902718","SRR8902718","SRR8902718","SRR8902718","SRR8902718","SRR8902718",
"SRR8902665","SRR8902665","SRR8902665","SRR8902665","SRR8902665",
"SRR8902714","SRR8902714","SRR8902714","SRR8902714","SRR8902714",
"SRR8902815","SRR8902815","SRR8902815","SRR8902815","SRR8902815","SRR8902815","SRR8902815","SRR8902815","SRR8902815","SRR8902815","SRR8902815"),
Gene = c("MEG_1019","MEG_1025","MEG_1041","MEG_1055","MEG_1057","MEG_1058","MEG_1061","MEG_1079",
"MEG_1016","MEG_1038","MEG_1039","MEG_1040","MEG_1060",
"MEG_4292","MEG_4293","MEG_4294","MEG_4296","MEG_4605",
"MEG_6622","MEG_6626","MEG_6627","MEG_6629","MEG_6632","MEG_6638","MEG_7015","MEG_7016","MEG_7024","MEG_7025","MEG_7026"),
Gene_Fraction = c(99.8794,95.8384,88.5327,95.1553,99.8758,98.1744,97.552,99.8776,
99.8744,88.8191,99.8744,99.4975,99.8753,
99.9332,99.9317,99.931,98.6497,99.8734,
86.1689,82.8641,83.1184,94.0024,86.7809,97.3072,93.9217,97.5853,99.9216,97.7273,84.0133)
)
# Complete the matrix with NAs for missing sample-gene combinations
data_complete <- complete(data, Sample, Gene, fill = list(Gene_Fraction = NA))
# Order genes and samples
data_complete$Gene <- factor(data_complete$Gene, levels = sort(unique(data$Gene)))
data_complete$Sample <- factor(data_complete$Sample)
# Plot
ggplot(data_complete, aes(x = Sample, y = Gene, fill = Gene_Fraction)) +
geom_tile(color = "white", linewidth = 0.4) +
geom_text(aes(label = ifelse(!is.na(Gene_Fraction), sprintf("%.1f", Gene_Fraction), "")),
size = 2.5, color = "black") +
scale_fill_gradient(low = "#fee8c8", high = "#b30000",
na.value = "grey90",
name = "Gene Fraction (%)",
limits = c(80, 100)) +
labs(title = "Gene Fraction Heatmap",
x = "Sample", y = "Gene") +
theme_minimal(base_size = 12) +
theme(
axis.text.x = element_text(angle = 30, hjust = 1, size = 9),
axis.text.y = element_text(size = 8),
plot.title = element_text(hjust = 0.5, face = "bold"),
legend.position = "right",
panel.grid = element_blank()
)
ggsave("heatmap.png", width = 8, height = 10, dpi = 150)
