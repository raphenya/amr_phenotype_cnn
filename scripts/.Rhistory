eurogasp_pheno <- eurogasp_pheno_raw %>%
mutate(across(c(Azithromycin, Ciprofloxacin, Cefixime, Ceftriaxone), as.character)) %>%
pivot_longer(
cols = c(Azithromycin, Ciprofloxacin, Cefixime, Ceftriaxone),
names_to = "antibiotic",
values_to = "mic"
)
View(eurogasp_pheno)
View(eurogasp_pheno)
